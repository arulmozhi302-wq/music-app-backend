# Use 5000 for local dev so the frontend proxy (vite.config.js) can reach the API
PORT=5000
# On Vercel: set MONGODB_URI (e.g. MongoDB Atlas) and JWT_SECRET in Project → Environment Variables
MONGODB_URI=mongodb+srv://b39-fsd:6m2ctkcWfghf5SRa@cluster0.aabihuz.mongodb.net
JWT_SECRET=music-app
NODE_ENV=development

# Optional: Cloudinary for uploads (if set, audio/cover go to Cloudinary instead of local uploads/)
# Get from https://cloudinary.com/console
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# For local file uploads (when Cloudinary not set)
UPLOAD_PATH=./uploads
AUDIO_PATH=./uploads/audio
COVER_PATH=./uploads/covers

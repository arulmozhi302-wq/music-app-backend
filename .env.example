PORT=5000
# On Vercel: set MONGODB_URI (e.g. MongoDB Atlas) and JWT_SECRET in Project → Environment Variables
MONGODB_URI=mongodb://localhost:27017/music-streaming
JWT_SECRET=music-app
NODE_ENV=development

# For file uploads - relative to backend root
UPLOAD_PATH=./uploads
AUDIO_PATH=./uploads/audio
COVER_PATH=./uploads/covers
